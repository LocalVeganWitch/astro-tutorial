---
import BaseLayout from "../layouts/BaseLayout.astro";

const images = Object.values(
  import.meta.glob("../assets/portfolio/*.{jpg,jpeg,png,webp,avif}", {
    eager: true,
    import: "default",
  })
).sort((a, b) => a.src.localeCompare(b.src));

const artwork = images.map((image) => {
  const filename = image.src.split("/").pop()?.split(".")[0] ?? "";

  const title = filename
    .replace(/[-_]/g, " ")
    .replace(/\b\w/g, (letter) => letter.toUpperCase());

  return {
    title,
    slug: filename,
    image,
  };
});
---

<BaseLayout pageTitle="Studio">

  <main>

    <section class="welcome reveal">

      <p class="greeting" id="greeting">
        Welcome.
      </p>

      <h2>
        ⁺☕︎ ˖·
      </h2>

    </section>

    <section class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-6">

      {artwork.map((piece, index) => (

        <article
          class="mb-6 break-inside-avoid reveal group"
          style={`--delay:${index * 100}ms`}
        >

          <a href={`/gallery/${piece.slug}`}>

            <figure class="overflow-hidden rounded-xl">

              <img
                src={piece.image.src}
                width={piece.image.width}
                height={piece.image.height}
                alt={piece.title}
                loading="lazy"
                class="w-full h-auto transition duration-300 group-hover:scale-[1.02]"
              />

              <figcaption
                class="absolute inset-0 flex flex-col justify-end bg-black/40 opacity-0 transition-opacity duration-300 group-hover:opacity-100 p-5 text-white"
              >

                <h2 class="text-lg font-semibold">
                  {piece.title}
                </h2>

                <span class="text-sm opacity-80">
                  View Piece →
                </span>

              </figcaption>

            </figure>

          </a>

        </article>

      ))}

    </section>

  </main>

  <script>
    const greeting = document.querySelector("#greeting");

    if (greeting) {
      const hour = new Date().getHours();

      greeting.textContent =
        hour >= 5 && hour < 12
          ? "Good morning."
          : hour >= 12 && hour < 18
          ? "Good afternoon."
          : "Good evening.";
    }
  </script>

</BaseLayout>