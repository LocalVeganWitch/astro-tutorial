---
import BaseLayout from "../layouts/BaseLayout.astro";

const artwork = [
  {
    title: "Forest Shrine",
    medium: "Watercolor",
    year: "2024",
    image: "/artwork/forest-shrine.jpg",
  },
  {
    title: "Moonlit Garden",
    medium: "Digital Illustration",
    year: "2025",
    image: "/artwork/moonlit-garden.jpg",
  },
  {
    title: "Herbal Study",
    medium: "Ink",
    year: "2024",
    image: "/artwork/herbal-study.jpg",
  },
  {
    title: "The Old Woods",
    medium: "Watercolor",
    year: "2023",
    image: "/artwork/old-woods.jpg",
  },
];
---

<BaseLayout pageTitle="Studio">

  <main>
      
    <section class="welcome reveal">

      <p class="greeting" id="greeting">
        Welcome.
      </p>

          <h2>
            ⁺☕︎ ˖·
          </h2>

    </section>


    <section class="gallery">

      {artwork.map((piece, index) => (
        <article 
          class="art-card reveal"
          style={`--delay:${index * 120}ms`}
        >

          <a href={`/gallery/${piece.title.toLowerCase().replaceAll(" ", "-")}`}>

            <figure>
              <img 
                src={piece.image}
                alt={piece.title}
                loading="lazy"
              />

              <figcaption>
                <h2>{piece.title}</h2>

                <p>
                  {piece.medium} · {piece.year}
                </p>

                <span>
                  View piece →
                </span>
              </figcaption>

            </figure>

          </a>

        </article>
      ))}

    </section>


  </main>

<script>
  const greeting = document.querySelector("#greeting");

  if (greeting) {
    const hour = new Date().getHours();

    if (hour >= 5 && hour < 12) {
      greeting.textContent = "Good morning.";
    } else if (hour >= 12 && hour < 18) {
      greeting.textContent = "Good afternoon.";
    } else {
      greeting.textContent = "Good evening.";
    }
  }
</script>

</BaseLayout>